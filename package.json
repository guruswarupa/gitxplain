{
  "name": "gitxplain",
  "version": "1.0.0",
  "private": true,
  "main": "dist/main.js",
  "homepage": "./",
  "scripts": {
    "dev": "concurrently -k \"webpack --config webpack.main.config.js --mode development --watch\" \"webpack serve --config webpack.renderer.config.js --mode development\" \"wait-on tcp:3000 file:dist/main.js file:dist/preload.js && electron . --dev\" \"python -m backend.main --dev\"",
    "electron-dev": "concurrently -k \"webpack --config webpack.main.config.js --mode development --watch\" \"webpack serve --config webpack.renderer.config.js --mode development\" \"wait-on tcp:3000 file:dist/main.js file:dist/preload.js && electron . --dev\"",
    "backend-dev": "python -m backend.main",
    "build": "tsc && webpack --config webpack.main.config.js --mode production && webpack --config webpack.renderer.config.js --mode production",
    "dist": "npm run build && electron-builder",
    "lint": "eslint .",
    "test": "node --no-warnings --test"
  },
